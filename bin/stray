#!/usr/bin/env bash
# Thin wrapper so users can run `stray` (or `!stray` inside Claude Code)
# to render the cached dashboard with zero model involvement.
#
# Flags:
#   --refresh, -r    Force a full cache refresh before rendering.
#   --html           Regenerate cache/dashboard.html, do NOT print or open.
#   --open, -o       Regenerate cache/dashboard.html and open it in browser.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")/.." && pwd)"

# --- Subcommand: spawn (DD-025) ---------------------------------------------
# Fan out a sub-card from the CURRENT session: starts an independent claude in a
# new git worktree, working on <task>, linked as a child of this session (parent
# = $CLAUDE_SESSION_ID, injected by Claude Code). The cockpit nests it under the
# current card. Run BY the parent session (or you) — we provide the primitive; we
# do NOT run an autonomous coordination loop.
#   Usage: stray spawn "<task>" [--name <slug>] [--no-worktree]
if [ "${1:-}" = "spawn" ]; then
  shift || true
  SPAWN_NAME=""; SPAWN_TASK=""; SPAWN_WT=1
  while [ $# -gt 0 ]; do
    case "$1" in
      --name) SPAWN_NAME="${2:-}"; shift 2 ;;
      --no-worktree) SPAWN_WT=0; shift ;;
      -h|--help) echo 'Usage: stray spawn "<task>" [--name <slug>] [--no-worktree]'; exit 0 ;;
      *) SPAWN_TASK="${SPAWN_TASK:+$SPAWN_TASK }$1"; shift ;;
    esac
  done
  [ -n "$SPAWN_TASK" ] || { echo 'stray spawn: 需要任务,例:stray spawn "修鉴权超时"' >&2; exit 1; }
  python3 - "${STRAY_PORT:-9876}" "$(pwd)" "${CLAUDE_SESSION_ID:-}" "$SPAWN_NAME" "$SPAWN_WT" "$SPAWN_TASK" <<'PY'
import json, sys, urllib.request
port, cwd, parent, name, wt, task = sys.argv[1:7]
body = json.dumps({"cwd": cwd, "worktree": wt == "1", "name": name,
                   "parent": parent, "prompt": task}).encode()
try:
    req = urllib.request.Request(f"http://127.0.0.1:{port}/api/new-session",
                                 data=body, headers={"Content-Type": "application/json"})
    j = json.load(urllib.request.urlopen(req, timeout=10))
except Exception as e:
    print("spawn 失败(serve 没在跑?):", e, file=sys.stderr); sys.exit(1)
if not j.get("url"):
    print("spawn 失败:", j.get("hint") or j.get("error") or j, file=sys.stderr); sys.exit(1)
print(f"✓ 子卡已起:{j.get('worktree_name') or '新会话'}  (worktree={j.get('worktree')})")
print("  几秒后它会作为子卡挂在当前卡下;在驾驶舱里打开它的终端即可驱动。")
PY
  exit $?
fi

DO_REFRESH=0
DO_HTML=0
DO_OPEN=0
DO_TREE=0
DO_SERVE=0
DO_DIAGNOSE=0
DO_COST=0
DO_BACKFILL=0
DO_PAUSE=0
DO_RESUME=0
DO_STATUS=0
DO_WEEKLY=0
DO_NEXT_STEPS=0
DO_TIPS=0
DO_WELLNESS=0
DO_CHECK_UPDATES=0
DO_UPDATE=0
NO_OPEN=0
DIAG_ARG=""
COST_ARG=""
PAUSE_REASON=""
WEEKLY_ARG="1"

# Pre-scan for --diagnose so we can capture its positional arg
while [ $# -gt 0 ]; do
  arg="$1"
  case "$arg" in
    --refresh|-r) DO_REFRESH=1; shift ;;
    --html)       DO_HTML=1; shift ;;
    --open|-o)    DO_OPEN=1; shift ;;
    --tree)       DO_TREE=1; shift ;;
    --serve|-s)   DO_SERVE=1; shift ;;
    --no-open)    NO_OPEN=1; shift ;;
    --diagnose|--diag)
      DO_DIAGNOSE=1
      shift
      # Optional session id as next non-flag arg
      if [ $# -gt 0 ] && [ "${1:0:1}" != "-" ]; then
        DIAG_ARG="$1"; shift
      fi
      ;;
    --cost)
      DO_COST=1
      shift
      # Optional subcommand: today | week | month | all | log | json
      if [ $# -gt 0 ] && [ "${1:0:1}" != "-" ]; then
        COST_ARG="$1"; shift
      fi
      ;;
    --backfill)
      DO_BACKFILL=1; shift ;;
    --pause)
      DO_PAUSE=1
      shift
      # Optional inline reason: --pause "weekend off"
      if [ $# -gt 0 ] && [ "${1:0:1}" != "-" ]; then
        PAUSE_REASON="$1"; shift
      fi
      ;;
    --resume)
      DO_RESUME=1; shift ;;
    --status)
      DO_STATUS=1; shift ;;
    --weekly-report)
      DO_WEEKLY=1
      shift
      # Optional offset: --weekly-report 2 = 2 weeks ago
      if [ $# -gt 0 ] && [ "${1:0:1}" != "-" ]; then
        WEEKLY_ARG="$1"; shift
      fi
      ;;
    --next-steps)
      DO_NEXT_STEPS=1; shift ;;
    --tips)
      DO_TIPS=1; shift ;;
    --wellness)
      DO_WELLNESS=1; shift ;;
    --check-updates|--check-update)
      DO_CHECK_UPDATES=1; shift ;;
    --update|--upgrade)
      DO_UPDATE=1; shift ;;
    -h|--help)
      cat <<EOF
Usage: stray [--refresh] [--serve | --open | --html | --tree | --diagnose]

Without flags: render the cached stray to stdout as an ANSI tree.

  --refresh, -r       Refresh cache (calls Claude) before rendering.
  --serve, -s         RECOMMENDED. Start a local server on 127.0.0.1:9876,
                      serve the HTML dashboard, and act as the Zellij jump
                      helper. Auto-opens the browser unless --no-open.
  --open, -o          Regenerate HTML files and open via file:// (no server,
                      falls back to File System Access for writes).
  --tree              Open the markmap tree view (cache/mindmap-tree.html).
  --html              Regenerate HTML files only, do not open anything.
  --no-open           With --serve: don't auto-open the browser.
  --diagnose [SID]    Show why a session may not appear in the dashboard.
                      Without SID, picks the most recently active session.
  --cost [PERIOD]     Show AI call counts and costs.
                      PERIOD: today | week | month | all | log | json.
                      Default (no arg): today + last 7 days table.
  --backfill          Re-summarize every session (one-shot migration).
                      Cost ~\$0.04 per session × ~200 sessions = ~\$8.
  --pause [REASON]    Engage the kill switch. The pipeline stops
                      processing on all subsequent hooks/triggers
                      until --resume. Optional REASON shows on the
                      dashboard banner.
  --resume            Release the kill switch.
  --status            Print current lifecycle JSON status.
  --weekly-report [N] Generate weekly report for N weeks ago (default 1
                      = last week). Output: cache/derived/reports/.
                      Cost ~\$0.10-0.50 depending on week density.
  --next-steps        Suggest 3 initiatives to focus on next.
                      Cost ~\$0.05. Auto-runs after each classify.
  --tips              Generate one data-anchored productivity tip.
                      Cost ~\$0.03. Daily cadence recommended.
  --wellness          Check for late-night / consecutive-day patterns
                      and emit a kind nudge if any fire. Skips AI
                      call entirely when no signal. Cost ~\$0.02 max.
  --check-updates     Compare your installed version against the
                      latest tag on origin/main and print whether an
                      update is available. Network-only — no install.
  --update            Pull the latest tagged release via
                      'git pull --ff-only'. Restart 'stray --serve'
                      after to pick up new code.
EOF
      exit 0
      ;;
    *)
      echo "Unknown flag: $arg" >&2
      echo "Try: stray --help" >&2
      exit 1
      ;;
  esac
done

if [ "$DO_DIAGNOSE" -eq 1 ]; then
  if [ -n "$DIAG_ARG" ]; then
    exec python3 "$REPO_ROOT/bin/diagnose.py" "$DIAG_ARG"
  else
    exec python3 "$REPO_ROOT/bin/diagnose.py"
  fi
fi

if [ "$DO_COST" -eq 1 ]; then
  if [ -n "$COST_ARG" ]; then
    exec python3 "$REPO_ROOT/bin/cost.py" "$COST_ARG"
  else
    exec python3 "$REPO_ROOT/bin/cost.py"
  fi
fi

if [ "$DO_PAUSE" -eq 1 ]; then
  if [ -n "$PAUSE_REASON" ]; then
    exec python3 "$REPO_ROOT/bin/_lifecycle.py" pause "$PAUSE_REASON"
  else
    exec python3 "$REPO_ROOT/bin/_lifecycle.py" pause
  fi
fi

if [ "$DO_RESUME" -eq 1 ]; then
  exec python3 "$REPO_ROOT/bin/_lifecycle.py" resume
fi

if [ "$DO_STATUS" -eq 1 ]; then
  exec python3 "$REPO_ROOT/bin/_lifecycle.py" status
fi

if [ "$DO_WEEKLY" -eq 1 ]; then
  exec python3 "$REPO_ROOT/bin/derived/weekly_report.py" --week "$WEEKLY_ARG"
fi

if [ "$DO_NEXT_STEPS" -eq 1 ]; then
  exec python3 "$REPO_ROOT/bin/derived/next_steps.py"
fi

if [ "$DO_TIPS" -eq 1 ]; then
  exec python3 "$REPO_ROOT/bin/derived/tips.py"
fi

if [ "$DO_WELLNESS" -eq 1 ]; then
  exec python3 "$REPO_ROOT/bin/derived/wellness.py"
fi

if [ "$DO_BACKFILL" -eq 1 ]; then
  echo "About to backfill summaries for all sessions."
  echo "This will call Haiku once per session (cost ~\$0.04/session)."
  N=$(ls "$REPO_ROOT/cache/sessions/" 2>/dev/null | wc -l | tr -d '[:space:]')
  S=$(ls "$REPO_ROOT/cache/summaries/" 2>/dev/null | wc -l | tr -d '[:space:]')
  echo "Sessions cached: $N    Summaries already present: $S"
  echo "Estimated to do: ~$((N - S)) calls, ~\$$(( (N - S) * 4 / 100 ))"
  echo
  read -r -p "Proceed? [y/N] " yn
  case "$yn" in
    y|Y|yes|YES) ;;
    *) echo "aborted"; exit 0 ;;
  esac
  exec bash "$REPO_ROOT/bin/pipeline-run.sh" --backfill --force-classify
fi

if [ "$DO_CHECK_UPDATES" -eq 1 ]; then
  exec python3 "$REPO_ROOT/bin/_updates.py"
fi

if [ "$DO_UPDATE" -eq 1 ]; then
  exec python3 "$REPO_ROOT/bin/_updates.py" update
fi

if [ "$DO_SERVE" -eq 1 ]; then
  if [ "$NO_OPEN" -eq 1 ]; then
    exec python3 "$REPO_ROOT/bin/serve.py" --no-open
  else
    exec python3 "$REPO_ROOT/bin/serve.py"
  fi
fi

if [ "$DO_REFRESH" -eq 1 ]; then
  # Sweep dirty + force a Layer 2 run at the end
  bash "$REPO_ROOT/bin/pipeline-run.sh" --all-dirty --force-classify >&2
fi

if [ "$DO_HTML" -eq 1 ] || [ "$DO_OPEN" -eq 1 ] || [ "$DO_TREE" -eq 1 ]; then
  # Always regenerate both so they're in sync.
  python3 "$REPO_ROOT/bin/render-html.py"
  python3 "$REPO_ROOT/bin/render-tree.py"
  TARGET="$REPO_ROOT/cache/dashboard.html"
  [ "$DO_TREE" -eq 1 ] && TARGET="$REPO_ROOT/cache/mindmap-tree.html"
  if [ "$DO_OPEN" -eq 1 ] || [ "$DO_TREE" -eq 1 ]; then
    if command -v open >/dev/null 2>&1; then
      open "$TARGET"
    elif command -v xdg-open >/dev/null 2>&1; then
      xdg-open "$TARGET"
    else
      echo "No browser opener found. File at: $TARGET" >&2
    fi
  fi
  exit 0
fi

exec python3 "$REPO_ROOT/bin/render.py"
